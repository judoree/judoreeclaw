{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "browser-agents",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-17",
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/screensshots/*"],
  },
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "BrowserAgent",
        "name": "BrowserAgent",
      },
    ],
  },
  "migrations": [
    {
      "new_sqlite_classes": ["BrowserAgent"],
      "tag": "1",
    },
  ],
  "browser": {
    "binding": "BROWSER",
    // "remote": true
  },
  "worker_loaders": [
    {
      "binding": "LOADER",
    },
  ],
  "r2_buckets": [
    {
      "bucket_name": "browser-agents-bucket",
      "binding": "FILES",
      "remote": true,
    },
  ],
}
